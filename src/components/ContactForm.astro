<div id="contact-form" class="p-8 rounded-2xl border" style="background-color: var(--color-bg-secondary); border-color: var(--color-border);">
    <h2 class="text-2xl font-black mb-8" style="color: var(--color-text);">Enviar mensaje</h2>

    <form id="contact-form" class="space-y-5">
          
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div class="space-y-2">
            <label class="text-sm font-medium" style="color: var(--color-text);">Nombre completo</label>
            <input
              type="text"
              name="nombre"
              placeholder="Juan Pérez"
              required
              class="w-full px-4 py-3 rounded-xl border text-sm outline-none transition-all duration-200"
              style="background-color: var(--color-bg); border-color: var(--color-border); color: var(--color-text);"
              onfocus="this.style.borderColor='var(--color-primary)'; this.style.boxShadow='0 0 0 3px rgba(37,99,235,0.1)'"
              onblur="this.style.borderColor='var(--color-border)'; this.style.boxShadow='none'"
            />
          </div>
          <div class="space-y-2">
            <label class="text-sm font-medium" style="color: var(--color-text);">Correo electrónico</label>
            <input
              type="email"
              name="email"
              placeholder="juan@correo.com"
              required
              class="w-full px-4 py-3 rounded-xl border text-sm outline-none transition-all duration-200"
              style="background-color: var(--color-bg); border-color: var(--color-border); color: var(--color-text);"
              onfocus="this.style.borderColor='var(--color-primary)'; this.style.boxShadow='0 0 0 3px rgba(37,99,235,0.1)'"
              onblur="this.style.borderColor='var(--color-border)'; this.style.boxShadow='none'"
            />
          </div>
        </div>
      
        <div class="space-y-2">
          <label class="text-sm font-medium" style="color: var(--color-text);">Teléfono</label>
          <input
            type="tel"
            name="telefono"
            placeholder="(506) 8888-8888"
            class="w-full px-4 py-3 rounded-xl border text-sm outline-none transition-all duration-200"
            style="background-color: var(--color-bg); border-color: var(--color-border); color: var(--color-text);"
            onfocus="this.style.borderColor='var(--color-primary)'; this.style.boxShadow='0 0 0 3px rgba(37,99,235,0.1)'"
            onblur="this.style.borderColor='var(--color-border)'; this.style.boxShadow='none'"
          />
        </div>
      
        <div class="space-y-2">
          <label class="text-sm font-medium" style="color: var(--color-text);">Asunto</label>
          <input
            type="text"
            name="asunto"
            placeholder="¿En qué podemos ayudarte?"
            required
            class="w-full px-4 py-3 rounded-xl border text-sm outline-none transition-all duration-200"
            style="background-color: var(--color-bg); border-color: var(--color-border); color: var(--color-text);"
            onfocus="this.style.borderColor='var(--color-primary)'; this.style.boxShadow='0 0 0 3px rgba(37,99,235,0.1)'"
            onblur="this.style.borderColor='var(--color-border)'; this.style.boxShadow='none'"
          />
        </div>
      
        <div class="space-y-2">
          <label class="text-sm font-medium" style="color: var(--color-text);">Mensaje</label>
          <textarea
            name="mensaje"
            rows="4"
            placeholder="Escribe tu mensaje aquí..."
            required
            class="w-full px-4 py-3 rounded-xl border text-sm outline-none transition-all duration-200 resize-none"
            style="background-color: var(--color-bg); border-color: var(--color-border); color: var(--color-text);"
            onfocus="this.style.borderColor='var(--color-primary)'; this.style.boxShadow='0 0 0 3px rgba(37,99,235,0.1)'"
            onblur="this.style.borderColor='var(--color-border)'; this.style.boxShadow='none'"
          ></textarea>
        </div>
      
        <!-- Mensaje de éxito/error -->
        <div id="form-feedback" class="hidden text-sm font-medium px-4 py-3 rounded-xl"></div>
      
        <button
          type="submit"
          id="submit-btn"
          class="w-full py-4 rounded-full text-white font-semibold transition-all duration-200 hover:scale-[1.02]"
          style="background-color: var(--color-primary);"
          onmouseover="this.style.backgroundColor='var(--color-primary-hover)'"
          onmouseout="this.style.backgroundColor='var(--color-primary)'"
        >
          Enviar mensaje
        </button>
      
      </form>

    <script>
        const form = document.querySelector('form') as HTMLFormElement;
        const feedback = document.getElementById('form-feedback') as HTMLDivElement;
        const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
      
        form?.addEventListener('submit', async (e) => {
          e.preventDefault();
      
          // Estado de carga
          submitBtn.textContent = 'Enviando...';
          submitBtn.disabled = true;
      
          const data = Object.fromEntries(new FormData(form));
      
          try {
            const res = await fetch('/api/contacto', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data)
            });
      
            if (res.ok) {
              feedback.textContent = '✅ Mensaje enviado correctamente. Te contactaremos pronto.';
              feedback.style.backgroundColor = 'var(--color-primary-light)';
              feedback.style.color = 'var(--color-primary)';
              feedback.classList.remove('hidden');
              form.reset();
            } else {
              throw new Error('Error del servidor');
            }
          } catch {
            feedback.textContent = '❌ Hubo un error al enviar. Inténtalo de nuevo.';
            feedback.style.backgroundColor = '#FEE2E2';
            feedback.style.color = '#DC2626';
            feedback.classList.remove('hidden');
          } finally {
            submitBtn.textContent = 'Enviar mensaje';
            submitBtn.disabled = false;
          }
        });
      </script>