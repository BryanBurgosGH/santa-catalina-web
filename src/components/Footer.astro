<footer class="py-16 px-6 border-t" style="background-color: var(--color-bg-secondary); border-color: var(--color-border);">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12">
  
      <!-- Marca -->
      <div class="space-y-4 md:col-span-2">
        <a href="/" class="text-xl font-black tracking-tight" style="color: var(--color-text);">
          Santa <span style="color: var(--color-primary);">Catalina</span>
        </a>
        <p class="text-sm leading-relaxed max-w-sm" style="color: var(--color-text-subtle);">
          Atención médica confiable y cercana para tu bienestar. Más de 10 años cuidando la salud de las familias costarricenses.
        </p>
        <!-- Redes -->
        <div class="flex gap-3 pt-2">
          {[
            { label: "Facebook", href: "#", svg: `<path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>` },
            { label: "Instagram", href: "#", svg: `<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>` },
            { label: "WhatsApp", href: "#", svg: `<path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/>` },
          ].map(red => (
            <a
              href={red.href}
              aria-label={red.label}
              class="w-9 h-9 rounded-full border flex items-center justify-center transition-all duration-200 hover:scale-110"
              style="border-color: var(--color-border); color: var(--color-text-subtle);"
              onmouseover="this.style.borderColor='var(--color-primary)'; this.style.color='var(--color-primary)'"
              onmouseout="this.style.borderColor='var(--color-border)'; this.style.color='var(--color-text-subtle)'"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={red.svg}/>
            </a>
          ))}
        </div>
      </div>
  
      <!-- Enlaces -->
      <div class="space-y-4">
        <p class="text-sm font-bold uppercase tracking-widest" style="color: var(--color-text);">Enlaces</p>
        <ul class="space-y-3">
          {[
            { label: "Inicio", href: "/" },
            { label: "Nosotros", href: "/nosotros" },
            { label: "Servicios", href: "/servicios" },
            { label: "Promociones", href: "/promociones" },
            { label: "Contacto", href: "/contacto" },
          ].map(link => (
            <li>
              <a
                href={link.href}
                class="text-sm transition-colors duration-200"
                style="color: var(--color-text-subtle);"
                onmouseover="this.style.color='var(--color-primary)'"
                onmouseout="this.style.color='var(--color-text-subtle)'"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
  
      <!-- Contacto -->
      <div class="space-y-4">
        <p class="text-sm font-bold uppercase tracking-widest" style="color: var(--color-text);">Contacto</p>
        <ul class="space-y-3">
          {[
            { label: "(506) 4032-3210", href: "tel:+50640323210" },
            { label: "contacto@santacatalinacr.com", href: "mailto:contacto@santacatalinacr.com" },
            { label: "Lun - Vie: 7am - 7pm", href: "#" },
            { label: "Sáb: 7am - 12pm", href: "#" },
          ].map(item => (
            <li>
              <a
                href={item.href}
                class="text-sm transition-colors duration-200"
                style="color: var(--color-text-subtle);"
                onmouseover="this.style.color='var(--color-primary)'"
                onmouseout="this.style.color='var(--color-text-subtle)'"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
  
    </div>
  
    <!-- Bottom -->
    <div class="max-w-7xl mx-auto mt-12 pt-8 border-t flex flex-col md:flex-row justify-between items-center gap-4" style="border-color: var(--color-border);">
      <p class="text-xs" style="color: var(--color-text-subtle);">
        © 2025 Clínica Santa Catalina. Todos los derechos reservados.
      </p>
      <p class="text-xs" style="color: var(--color-text-subtle);">
        Hecho con ❤️ en Costa Rica
      </p>
    </div>
  </footer>