---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout title="Contacto">

  <!-- Hero -->
  <section class="relative pt-24 pb-24 px-6 overflow-hidden" style="background-color: var(--color-bg);">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 -left-40 w-[500px] h-[500px] rounded-full blur-3xl opacity-10" style="background-color: var(--color-primary);"></div>
    </div>

    <div class="relative z-10 max-w-3xl mx-auto text-center space-y-6">
      <p id="contact-badge" class="text-sm font-semibold uppercase tracking-widest" style="color: var(--color-primary);">Estamos aquí para ayudarte</p>
      <h1 id="contact-title" class="text-5xl md:text-6xl font-black leading-tight" style="color: var(--color-text);">
        Envíanos tu<br/>
        <span style="color: var(--color-primary);">mensaje</span>
      </h1>
      <p id="contact-desc" class="text-lg" style="color: var(--color-text-subtle);">
        Comunícate con nosotros por el canal que prefieras. Nuestro equipo estará listo para brindarte la atención que mereces.
      </p>
    </div>
  </section>

  <!-- Contenido principal -->
  <section class="pt-24 pb-24 px-6" style="background-color: var(--color-bg);">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 items-start">

      <!-- Info de contacto -->
      <div id="contact-info" class="space-y-6">

        {[
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>`,
            title: "Llámanos",
            lines: ["(506) 4032-3210", "Lunes a Viernes: 7am - 7pm"]
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
            title: "Urgencias 24/7",
            lines: ["(506) 4032-5210", "Disponible todos los días"]
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>`,
            title: "Visítanos",
            lines: ["Oficinas administrativas", "San José, Costa Rica"]
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>`,
            title: "Escríbenos",
            lines: ["contacto@santacatalinacr.com", "Respondemos en menos de 24h"]
          },
        ].map(item => (
          <div class="contact-item flex gap-4 p-6 rounded-2xl border transition-all duration-300"
            style="background-color: var(--color-bg-secondary); border-color: var(--color-border);"
            onmouseover="this.style.borderColor='var(--color-primary)'; this.style.boxShadow='0 10px 30px rgba(37,99,235,0.08)'"
            onmouseout="this.style.borderColor='var(--color-border)'; this.style.boxShadow='none'"
          >
            <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0" style="background-color: var(--color-primary-light);">
              <svg class="w-5 h-5" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={item.icon}/>
            </div>
            <div>
              <p class="font-bold mb-1" style="color: var(--color-text);">{item.title}</p>
              {item.lines.map(line => (
                <p class="text-sm" style="color: var(--color-text-subtle);">{line}</p>
              ))}
            </div>
          </div>
        ))}

      </div>

      <!-- Formulario -->
      <ContactForm> </ContactForm>

    </div>
  </section>

</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
  tl.from('#contact-badge', { opacity: 0, y: 20, duration: 0.6 })
    .from('#contact-title', { opacity: 0, y: 40, duration: 0.8 }, '-=0.3')
    .from('#contact-desc',  { opacity: 0, y: 30, duration: 0.6 }, '-=0.4');

  gsap.from('#contact-info', {
    scrollTrigger: { trigger: '#contact-info', start: 'top 80%' },
    opacity: 0, x: -40, duration: 0.8, ease: 'power3.out'
  });

  gsap.from('.contact-item', {
    scrollTrigger: { trigger: '#contact-info', start: 'top 75%' },
    opacity: 0, y: 30, duration: 0.5, stagger: 0.12, ease: 'power3.out'
  });

  gsap.from('#contact-form', {
    scrollTrigger: { trigger: '#contact-form', start: 'top 80%' },
    opacity: 0, x: 40, duration: 0.8, ease: 'power3.out'
  });
</script>